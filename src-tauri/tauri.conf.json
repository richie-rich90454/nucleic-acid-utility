{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Nucleic Acid Utility",
  "version": "1.2.0",
  "identifier": "com.richierich.nucleicacid",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:6001",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Nucleic Acid Utility",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
